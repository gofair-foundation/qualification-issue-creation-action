{
  "name": "curation-issue-creation-action",
  "description": "Manages GitHub issues for FSR curation",
  "version": "2.0.0",
  "author": "",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/gofair-foundation/qualification-issue-creation-action",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gofair-foundation/qualification-issue-creation-action.git"
  },
  "bugs": {
    "url": "https://github.com/gofair-foundation/qualification-issue-creation-action/issues"
  },
  "keywords": [
    "FSR",
    "curation"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "coverage": "npx make-coverage-badge --output-path ./badges/coverage.svg",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "local-action": "npx @github/local-action . src/main.js .env",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.js",
    "package:watch": "npm run package -- --watch",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run coverage && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/http-client": "^4.0.0",
    "@octokit/auth-action": "^6.0.1",
    "@octokit/rest": "^21.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@github/local-action": "^2.2.1",
    "@jest/globals": "^30.3.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.13.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "rollup": "^4.57.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  }
}
